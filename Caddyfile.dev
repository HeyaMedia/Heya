# Dev-only front door for Heya. Sits on :8080, forwards /api/* (HTTP + WS)
# to `heya serve` on :3050 (run by air), everything else to Nuxt on :3000.
#
# Caddy stays alive across air rebuilds and Nuxt restarts, so the browser's
# HMR socket and any in-flight WS connection survive backend churn. The two
# downstreams can come and go independently without the page losing its
# anchor.
#
# Production is unaffected: `heya serve` defaults to :8080 and serves the
# embedded SPA from a single binary — no Caddy in front.

{
	auto_https off
	admin off
	persist_config off
}

:8080 {
	@api path /api/*
	reverse_proxy @api localhost:3050
	reverse_proxy localhost:3000
}
