# Heya configuration — copy to .env and edit.
#
# Every operational setting can be set here. When a field IS set via env,
# the corresponding UI control in /settings is disabled with a tooltip
# naming the env var that locked it. When a field is NOT set here, the
# UI in /settings is the source of truth (values persist in the database).
#
# Exceptions to this rule:
#   - "Infrastructure" block below is always env-only — never UI-editable.
#   - Admin bootstrap is first-boot-only — the env vars are ignored on
#     subsequent boots; password rotation happens in the UI.
#   - Scheduled tasks (scan/refresh/trickplay/thumbnails/etc) are
#     defaults + UI only — no env vars; configure in /settings/tasks.
#   - Per-library tunables (trickplay on/off, NFO mode, refresh schedule,
#     etc) are DB/UI only — env only declares library identity below.

# === Infrastructure (always ENV, never UI-editable) ===
HEYA_DATABASE_URL=postgres://heya:heya@localhost:5440/heya?sslmode=disable
HEYA_DB_MAX_CONNS=16
HEYA_DB_MIN_CONNS=2
# Passive mode: run as a read-mostly guest on the DB. Disables auto-migrate,
# env bootstrap, River workers, filesystem watchers, the scheduler tick loop,
# sonic-analysis, and startup orphan-rescue. Intended for local dev pointed at
# a production HEYA_DATABASE_URL: you get a live UI over real data without this
# process processing jobs or scanning a /storage path that isn't mounted here.
# The HTTP API still serves and can still write (edits hit the real DB) — use a
# read-only Postgres role if you want a hard wall. See docs/development.md.
HEYA_PASSIVE_MODE=false
# Allow ACTIVE mode (workers/scanner/watchers) against a NON-local database.
# Default false: a source/dev checkout pointed at a remote DB must stay
# PASSIVE_MODE=true, else it becomes a second worker pool on that DB's queue and
# soft-deletes libraries scanning paths that aren't mounted here — serve refuses
# to boot in that combination. The deployed container image sets this true (it
# owns its remote DB); `--dev-backend` can never satisfy it. A local DB always
# passes regardless. Leave UNSET in local dev.
HEYA_ALLOW_REMOTE_ACTIVE=false
# Passive mode only: another Heya instance to fetch image bytes from, since the
# borrowed DB's image files aren't on local disk. Point it at your production
# base URL (no trailing path), e.g. https://heya.example.ts.net. Empty → images
# 404 in passive mode.
HEYA_IMAGE_PROXY_URL=
HEYA_HOST=0.0.0.0
HEYA_PORT=8080
HEYA_LOG_LEVEL=info               # trace|debug|info|warn|error
HEYA_LOG_FORMAT=console           # console|json
HEYA_DATA_DIR=./data
# Canonical metadata service. Active-mode startup requires its readiness check
# to pass; inside Docker this must be an address reachable from the container.
HEYA_METADATA_URL=http://localhost:3030
# Optional HeyaMetadata bearer token; never exposed through Heya's API.
# HEYA_METADATA_API_KEY=
# Optional key for Heya's direct TheIntroDB community-segment client.
# HEYA_THEINTRODB_API_KEY=

# === Transcoder (ENV optional; locks UI when set) ===
HEYA_HWACCEL=auto                 # auto|none|videotoolbox|nvenc|vaapi|qsv
HEYA_TRANSCODE_CACHE_DIR=         # default: {HEYA_DATA_DIR}/transcode
HEYA_TRANSCODE_CACHE_MAX_GB=50

# === Server-side casting (ENV optional; locks UI when set) ===
# URL-pull receivers (Chromecast, then DLNA/Yamaha/WiiM) must be able to fetch
# media back from Heya. Leave empty to derive http://<server-LAN-IP>:HEYA_PORT
# per receiver. Set this when Heya sits behind a reverse proxy, Kubernetes
# Service, or another address the receiver can reach more reliably.
# HEYA_CAST_BASE_URL=https://heya.example.lan
# HEYA_CAST_ENABLED=true
# HEYA_CAST_DEVICES=192.168.1.216,192.168.1.242

# === Jellyfin-compatible API (ENV optional; locks UI when set) ===
# When enabled, Heya answers the Jellyfin client API (/System/Info/Public,
# /Users/AuthenticateByName, /Items, /socket, /emby/*...) so stock Jellyfin
# apps — Infuse, Finamp, Streamyfin, Findroid, jellyfin-web — can use Heya
# as their server. Advertises itself as Jellyfin 10.11.x. Also toggleable
# live from Settings when this var is unset.
# HEYA_JELLYFIN_API_ENABLED=false

# === Tailscale (ENV optional; locks UI when set; all OFF by default) ===
HEYA_TAILSCALE_ENABLED=false
HEYA_TAILSCALE_HOSTNAME=heya
HEYA_TAILSCALE_STATE_DIR=         # default: {HEYA_DATA_DIR}/tailscale
HEYA_TAILSCALE_HTTPS=false
HEYA_TAILSCALE_FUNNEL=false
HEYA_TAILSCALE_AUTHKEY=           # bootstrap only; never persisted, never UI-visible

# --- Remote access (UPnP + ACME certs + reachability; production-only) ---
# All UI-editable unless marked env-only; env values lock the Settings UI.
HEYA_REMOTE_ENABLED=false
HEYA_REMOTE_PORT=0                # 0 = mint a random 20000-59999 port once and persist it
HEYA_REMOTE_CHECK_URL=            # env-only; default https://heya.media
HEYA_REMOTE_CERT_DIR=             # env-only; default {HEYA_DATA_DIR}/remote
HEYA_REMOTE_ACME_CA=              # env-only; empty = Let's Encrypt production (set staging URL for tests)
HEYA_REMOTE_ACME_EMAIL=
HEYA_REMOTE_DNS_PROVIDER=         # desec | duckdns | cloudflare
HEYA_REMOTE_DNS_TOKEN=            # provider API token; never exposed via API
HEYA_REMOTE_DOMAIN=               # e.g. myname.dedyn.io / myname.duckdns.org / example.com
HEYA_REMOTE_SUBDOMAIN=            # optional label: heya -> wan.heya.example.com

# === Sonic Analysis (ENV optional; locks UI when set) ===
HEYA_SONIC_ENABLED=false
HEYA_SONIC_ACCELERATOR=auto       # auto|cpu|coreml|cuda|openvino|directml
# auto picks the best EP compiled into this image's onnxruntime: CoreML on
# macOS, else CUDA→OpenVINO→CPU on Linux. The GPU EPs only exist in the GPU
# image variants (ghcr heya:cuda / heya:openvino) — the base image is CPU-only
# for ONNX. cuda needs `--gpus all`; openvino needs `--device /dev/dri`.
# HEYA_SONIC_OPENVINO_DEVICE=GPU   # OpenVINO target: GPU|CPU|AUTO|GPU.1 (default GPU)

# === AI subsystem (ENV optional; locks UI when set; OFF by default) ===
# local = managed llama-server; external = OpenAI-compatible API;
# claude/codex = bundled official CLI using an existing subscription.
# HEYA_AI_MODE=off                  # off|local|external|claude|codex
# HEYA_AI_PROVIDER=openrouter       # preset id — `heya ai providers` lists them
# HEYA_AI_API_KEY=                  # bearer key for the external provider
# HEYA_AI_MODEL=                    # provider model id (external mode)
# HEYA_AI_BASE_URL=                 # OpenAI-compatible root, provider=custom only
# HEYA_AI_LOCAL_MODEL=qwen3-4b-instruct-2507  # curated GGUF catalog id
# HEYA_AI_LOCAL_BACKEND=auto        # auto|cpu|vulkan (vulkan: openvino image)
# HEYA_AI_CONTEXT=16384             # llama-server context window (KV-cache RAM!)
# HEYA_AI_CLAUDE_MODEL=sonnet       # alias or exact Claude model id
# HEYA_AI_CODEX_MODEL=gpt-5.6-luna  # model returned by Codex model/list
# HEYA_AI_CLAUDE_TOKEN=             # output from `claude setup-token`
# HEYA_AI_CLAUDE_BINARY=claude      # optional official CLI path override
# HEYA_AI_CODEX_BINARY=codex        # optional official CLI path override
# HEYA_AI_USE_SYSTEM_AGENTS=false   # dev only: reuse normal CLI login/config homes

# === Libraries (ENV declares identity; tunables stay DB/UI) ===
# Repeat with _0_, _1_, _2_ ... — gaps of up to 3 consecutive indices are tolerated.
# When set, NAME / PATHS / TYPE are locked in the UI for that library.
# All other library settings (trickplay, NFO, refresh schedule, etc.)
# remain DB-editable in Settings → Libraries.
# HEYA_LIBRARY_0_NAME=Music
# HEYA_LIBRARY_0_PATHS=/storage/Music,/storage/NewMusic
# HEYA_LIBRARY_0_TYPE=music         # movie|tv|anime|music|book|comic|podcast|radio
# HEYA_LIBRARY_1_NAME=Movies
# HEYA_LIBRARY_1_PATHS=/storage/Movies
# HEYA_LIBRARY_1_TYPE=movie

# === Podcast Index API (free dev tier — https://api.podcastindex.org) ===
# When unset, the trending+search endpoints return a clear error and the
# UI surfaces a "set the key in Settings" prompt. Personal-use traffic
# fits comfortably under the free quota.
# HEYA_PODCAST_INDEX_KEY=
# HEYA_PODCAST_INDEX_SECRET=

# === Admin bootstrap (applied only when no admin user exists) ===
# Ignored on subsequent boots; admin rotates password normally via UI.
# HEYA_ADMIN_USERNAME=admin
# HEYA_ADMIN_EMAIL=admin@example.com
# HEYA_ADMIN_PASSWORD=

# === Dev (only read by `heya dev-proxy` / `make dev`) ===
# The dev front door reverse-proxies these two upstreams; defaults match the
# `make dev` topology — override only if you remap ports.
# HEYA_DEV_PROXY=http://localhost:3000      # Nuxt/Vite dev server  (everything non-/api)
# HEYA_DEV_BACKEND=http://localhost:3050    # air-run `heya serve --dev-backend`  (/api/*)
#
# To exercise Tailscale in dev, give the dev node a DISTINCT identity in
# .env.local so it never clobbers a prod node:
#   HEYA_TAILSCALE_HOSTNAME=heya-dev
#   HEYA_TAILSCALE_STATE_DIR=./data/tailscale-dev
# Then either set HEYA_TAILSCALE_ENABLED=true (comes up at boot; UI shows it
# env-locked), or leave it unset and flip it from Settings → Tailscale — the
# DB-backed toggle flows through the backend to the dev-proxy's tailnet node.

# Last.fm application credentials (server-level; per-user sessions link in
# Settings → Music services). History import needs only the key.
#HEYA_LASTFM_API_KEY=
#HEYA_LASTFM_SECRET=
