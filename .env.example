# Heya configuration — copy to .env and edit.
#
# Every operational setting can be set here. When a field IS set via env,
# the corresponding UI control in /settings is disabled with a tooltip
# naming the env var that locked it. When a field is NOT set here, the
# UI in /settings is the source of truth (values persist in the database).
#
# Exceptions to this rule:
#   - "Infrastructure" block below is always env-only — never UI-editable.
#   - Admin bootstrap is first-boot-only — the env vars are ignored on
#     subsequent boots; password rotation happens in the UI.
#   - Scheduled tasks (scan/refresh/trickplay/thumbnails/etc) are
#     defaults + UI only — no env vars; configure in /settings/tasks.
#   - Per-library tunables (trickplay on/off, NFO mode, refresh schedule,
#     etc) are DB/UI only — env only declares library identity below.

# === Infrastructure (always ENV, never UI-editable) ===
HEYA_DATABASE_URL=postgres://heya:heya@localhost:5440/heya?sslmode=disable
HEYA_DB_MAX_CONNS=16
HEYA_DB_MIN_CONNS=2
HEYA_HOST=0.0.0.0
HEYA_PORT=8080
HEYA_LOG_LEVEL=info               # trace|debug|info|warn|error
HEYA_LOG_FORMAT=console           # console|json
HEYA_DATA_DIR=./data
HEYA_MEDIA_URL=https://heya.media # upstream metadata aggregator

# === Transcoder (ENV optional; locks UI when set) ===
HEYA_HWACCEL=auto                 # auto|none|videotoolbox|nvenc|vaapi|qsv
HEYA_TRANSCODE_CACHE_DIR=         # default: {HEYA_DATA_DIR}/transcode
HEYA_TRANSCODE_CACHE_MAX_GB=50

# === Tailscale (ENV optional; locks UI when set; all OFF by default) ===
HEYA_TAILSCALE_ENABLED=false
HEYA_TAILSCALE_HOSTNAME=heya
HEYA_TAILSCALE_STATE_DIR=         # default: {HEYA_DATA_DIR}/tailscale
HEYA_TAILSCALE_HTTPS=false
HEYA_TAILSCALE_FUNNEL=false
HEYA_TAILSCALE_AUTHKEY=           # bootstrap only; never persisted, never UI-visible

# === Sonic Analysis (ENV optional; locks UI when set) ===
HEYA_SONIC_ENABLED=false
HEYA_SONIC_ACCELERATOR=auto       # auto|cpu|coreml|cuda|openvino|directml
# auto picks the best EP compiled into this image's onnxruntime: CoreML on
# macOS, else CUDA→OpenVINO→CPU on Linux. The GPU EPs only exist in the GPU
# image variants (ghcr heya:cuda / heya:openvino) — the base image is CPU-only
# for ONNX. cuda needs `--gpus all`; openvino needs `--device /dev/dri`.
# HEYA_SONIC_OPENVINO_DEVICE=GPU   # OpenVINO target: GPU|CPU|AUTO|GPU.1 (default GPU)

# === Libraries (ENV declares identity; tunables stay DB/UI) ===
# Repeat with _0_, _1_, _2_ ... — gaps of up to 3 consecutive indices are tolerated.
# When set, NAME / PATHS / TYPE are locked in the UI for that library.
# All other library settings (trickplay, NFO, refresh schedule, etc.)
# remain DB-editable in Settings → Libraries.
# HEYA_LIBRARY_0_NAME=Music
# HEYA_LIBRARY_0_PATHS=/storage/Music,/storage/NewMusic
# HEYA_LIBRARY_0_TYPE=music         # movie|tv|music|book|comic|podcast|radio
# HEYA_LIBRARY_1_NAME=Movies
# HEYA_LIBRARY_1_PATHS=/storage/Movies
# HEYA_LIBRARY_1_TYPE=movie

# === Podcast Index API (free dev tier — https://api.podcastindex.org) ===
# When unset, the trending+search endpoints return a clear error and the
# UI surfaces a "set the key in Settings" prompt. Personal-use traffic
# fits comfortably under the free quota.
# HEYA_PODCAST_INDEX_KEY=
# HEYA_PODCAST_INDEX_SECRET=

# === Admin bootstrap (applied only when no admin user exists) ===
# Ignored on subsequent boots; admin rotates password normally via UI.
# HEYA_ADMIN_USERNAME=admin
# HEYA_ADMIN_EMAIL=admin@example.com
# HEYA_ADMIN_PASSWORD=

# === Dev (only read by `heya dev-proxy` / `make dev`) ===
# The dev front door reverse-proxies these two upstreams; defaults match the
# `make dev` topology — override only if you remap ports.
# HEYA_DEV_PROXY=http://localhost:3000      # Nuxt/Vite dev server  (everything non-/api)
# HEYA_DEV_BACKEND=http://localhost:3050    # air-run `heya serve --dev-backend`  (/api/*)
# HEYA_DEV_TS_CONTROL=tmp/heya-dev-ts.sock  # localhost socket the backend drives Tailscale through
#
# To exercise Tailscale in dev, give the dev node a DISTINCT identity in
# .env.local so it never clobbers a prod node:
#   HEYA_TAILSCALE_HOSTNAME=heya-dev
#   HEYA_TAILSCALE_STATE_DIR=./data/tailscale-dev
# Then either set HEYA_TAILSCALE_ENABLED=true (comes up at boot; UI shows it
# env-locked), or leave it unset and flip it from Settings → Tailscale — the
# DB-backed toggle flows through the backend to the dev-proxy's tailnet node.
